---
layout: null
permalink: /catalog/blog.jsonl
sitemap: false
---
{% for post in site.categories.blog -%}
{"_id":{{ post.url | remove: "/" | jsonify }},"name":{{ post.title | jsonify }},"url":{{ post.url | absolute_url | jsonify }},"categories":[{"type":"c","_id":"blog","name":"Blog"}],"author":{{ post.author | default: site.name | jsonify }},"publishDate":{{ post.date | date: "%Y-%m-%d" | jsonify }},"description":{% if post.description %}{{ post.description | jsonify }}{% else %}{{ post.content | strip_html | strip_newlines | strip | truncate: 500 | jsonify }}{% endif %},"tags":[{% if post.tags %}{% for t in post.tags %}{"type":"t","_id":{{ t | jsonify }},"name":{{ t | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}]}
{% endfor -%}
