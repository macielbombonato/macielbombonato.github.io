{% for career in site.categories.career -%}
{"_id":{{ career.url | remove: "/" | jsonify }},"name":{{ career.title | jsonify }},"url":{{ career.url | absolute_url | jsonify }},"categories":[{"type":"c","_id":"career","name":"Carreira"}],"author":{{ career.author | default: site.name | jsonify }},"publishDate":{{ career.date | date: "%Y-%m-%d" | jsonify }},"description":{% if career.description %}{{ career.description | jsonify }}{% else %}{{ career.content | strip_html | strip_newlines | strip | truncate: 500 | jsonify }}{% endif %},"tags":[{% if career.tags %}{% for t in career.tags %}{"type":"t","_id":{{ t | jsonify }},"name":{{ t | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}{% endif %}],"attributes":{"company":{% if career.company and career.company != "" %}{{ career.company | jsonify }}{% else %}null{% endif %},"startDate":{{ career.date | date: "%Y-%m-%d" | jsonify }},"endDate":{% if career.end and career.end != "" %}{{ career.end | date: "%Y-%m-%d" | jsonify }}{% else %}null{% endif %},"location":{% if career.location and career.location != "" %}{{ career.location | jsonify }}{% else %}null{% endif %},"industry":{% if career.industry and career.industry != "" %}{{ career.industry | jsonify }}{% else %}null{% endif %},"seniority":{% if career.seniority and career.seniority != "" %}{{ career.seniority | jsonify }}{% else %}null{% endif %},"technologies":{% if career.technologies and career.technologies != empty %}{{ career.technologies | join: "," | jsonify }}{% else %}""{% endif %}}}
{% endfor -%}
